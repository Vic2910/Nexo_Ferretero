</div>

<!-- Script para cambiar entre secciones sin recargar -->
<script>
    (function() {
        // Obtener todos los enlaces del menú lateral
        const menuLinks = document.querySelectorAll('.admin-menu a');
        const sections = document.querySelectorAll('.section');

        // Función para activar una sección
        function activateSection(sectionId) {
            // Ocultar todas las secciones
            sections.forEach(section => {
                section.classList.remove('active');
            });
            // Mostrar la sección seleccionada
            const activeSection = document.getElementById(sectionId);
            if (activeSection) {
                activeSection.classList.add('active');
            }
            // Actualizar clase activa en el menú
            menuLinks.forEach(link => {
                link.classList.remove('active');
                if (link.dataset.section === sectionId) {
                    link.classList.add('active');
                }
            });
        }

        // Asignar evento click a cada enlace
        menuLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                const sectionId = this.dataset.section;
                if (!sectionId) {
                    return;
                }

                e.preventDefault(); // Evitar recarga de página
                activateSection(sectionId);
            });
        });

        // Activar la sección de usuarios por defecto (ya tiene clase active, pero aseguramos)
        // También se puede leer de la URL si se quiere, pero por ahora dejamos usuarios
        // Nota: si hay un hash en la URL, podríamos activar esa sección
        const drawer = document.getElementById('categoryDrawer');
        const overlay = document.getElementById('categoryDrawerOverlay');
        const openButton = document.getElementById('openCategoryDrawer');
        const closeButton = document.getElementById('closeCategoryDrawer');
        const cancelButton = document.getElementById('cancelCategoryDrawer');
        const productDrawer = document.getElementById('productDrawer');
        const productOverlay = document.getElementById('productDrawerOverlay');
        const openProductButton = document.getElementById('openProductDrawer');
        const closeProductButton = document.getElementById('closeProductDrawer');
        const cancelProductButton = document.getElementById('cancelProductDrawer');
        const categoryDrawerTitle = document.getElementById('categoryDrawerTitle');
        const categoryDrawerSubmit = document.getElementById('categoryDrawerSubmit');
        const categoryFormIdInput = document.getElementById('Form_Id');
        const categoryFormNameInput = document.getElementById('Form_Name');
        const categoryFormDescriptionInput = document.getElementById('Form_Description');
        const productDrawerTitle = document.getElementById('productDrawerTitle');
        const productDrawerSubmit = document.getElementById('productDrawerSubmit');
        const productFormIdInput = document.getElementById('ProductForm_Id');
        const productFormNameInput = document.getElementById('ProductForm_Name');
        const productFormPriceInput = document.getElementById('ProductForm_Price');
        const productFormStockInput = document.getElementById('ProductForm_Stock');
        const productFormMinStockInput = document.getElementById('ProductForm_MinStock');
        const productFormDescriptionInput = document.getElementById('ProductForm_Description');
        const productFormCategoryInput = document.getElementById('ProductForm_CategoryId');
        const productFormImage1Input = document.getElementById('ProductForm_ImageUrl1');
        const productFormImage2Input = document.getElementById('ProductForm_ImageUrl2');
        const productFormImage3Input = document.getElementById('ProductForm_ImageUrl3');

        function setCategoryCreateMode() {
            if (categoryFormIdInput) {
                categoryFormIdInput.value = '';
            }

            if (categoryFormNameInput) {
                categoryFormNameInput.value = '';
            }

            if (categoryFormDescriptionInput) {
                categoryFormDescriptionInput.value = '';
            }

            if (categoryDrawerTitle) {
                categoryDrawerTitle.textContent = 'Nueva categoría';
            }

            if (categoryDrawerSubmit) {
                categoryDrawerSubmit.textContent = 'Guardar categoría';
            }
        }

        function setProductCreateMode() {
            if (productFormIdInput) {
                productFormIdInput.value = '';
            }

            if (productDrawerTitle) {
                productDrawerTitle.textContent = 'Nuevo producto';
            }

            if (productDrawerSubmit) {
                productDrawerSubmit.textContent = 'Guardar producto';
            }
        }

        function setCategoryEditMode(row) {
            if (!row) {
                return;
            }

            if (categoryFormIdInput) {
                categoryFormIdInput.value = row.dataset.categoryId || '';
            }

            if (categoryFormNameInput) {
                categoryFormNameInput.value = row.dataset.categoryRawName || '';
            }

            if (categoryFormDescriptionInput) {
                categoryFormDescriptionInput.value = row.dataset.categoryRawDescription || '';
            }

            if (categoryDrawerTitle) {
                categoryDrawerTitle.textContent = 'Editar categoría';
            }

            if (categoryDrawerSubmit) {
                categoryDrawerSubmit.textContent = 'Guardar cambios';
            }
        }

        function setProductEditMode(row) {
            if (!row) {
                return;
            }

            if (productFormIdInput) {
                productFormIdInput.value = row.dataset.productId || '';
            }

            if (productFormNameInput) {
                productFormNameInput.value = row.dataset.productRawName || '';
            }

            if (productFormPriceInput) {
                productFormPriceInput.value = row.dataset.productRawPrice || '';
            }

            if (productFormStockInput) {
                productFormStockInput.value = row.dataset.productRawStock || '';
            }

            if (productFormMinStockInput) {
                productFormMinStockInput.value = row.dataset.productRawMinStock || '';
            }

            if (productFormDescriptionInput) {
                productFormDescriptionInput.value = row.dataset.productRawDescription || '';
            }

            if (productFormCategoryInput) {
                productFormCategoryInput.value = row.dataset.productCategoryId || '';
            }

            if (productFormImage1Input) {
                productFormImage1Input.value = row.dataset.productImage1 || '';
            }

            if (productFormImage2Input) {
                productFormImage2Input.value = row.dataset.productImage2 || '';
            }

            if (productFormImage3Input) {
                productFormImage3Input.value = row.dataset.productImage3 || '';
            }

            if (productDrawerTitle) {
                productDrawerTitle.textContent = 'Editar producto';
            }

            if (productDrawerSubmit) {
                productDrawerSubmit.textContent = 'Guardar cambios';
            }
        }

        function openDrawer() {
            drawer?.classList.add('open');
            drawer?.setAttribute('aria-hidden', 'false');
            if (overlay) {
                overlay.hidden = false;
            }
        }

        function closeDrawer() {
            drawer?.classList.remove('open');
            drawer?.setAttribute('aria-hidden', 'true');
            if (overlay) {
                overlay.hidden = true;
            }
        }

        function openProductDrawer() {
            productDrawer?.classList.add('open');
            productDrawer?.setAttribute('aria-hidden', 'false');
            if (productOverlay) {
                productOverlay.hidden = false;
            }
        }

        function closeProductDrawer() {
            productDrawer?.classList.remove('open');
            productDrawer?.setAttribute('aria-hidden', 'true');
            if (productOverlay) {
                productOverlay.hidden = true;
            }
        }

        openButton?.addEventListener('click', () => {
            setCategoryCreateMode();
            openDrawer();
        });
        closeButton?.addEventListener('click', closeDrawer);
        cancelButton?.addEventListener('click', () => {
            setCategoryCreateMode();
            closeDrawer();
        });
        overlay?.addEventListener('click', closeDrawer);
        openProductButton?.addEventListener('click', () => {
            setProductCreateMode();
            openProductDrawer();
        });
        closeProductButton?.addEventListener('click', closeProductDrawer);
        cancelProductButton?.addEventListener('click', () => {
            setProductCreateMode();
            closeProductDrawer();
        });
        productOverlay?.addEventListener('click', closeProductDrawer);

        const container = document.querySelector('.admin-container');
        const forcedSection = (container?.dataset.activeSection || '').trim();

        if (forcedSection) {
            activateSection(forcedSection);
        }
        else if (window.location.hash) {
            const hash = window.location.hash.substring(1);
            activateSection(hash);
        }
        else {
            const params = new URLSearchParams(window.location.search);
            const requestedSection = (params.get('section') || '').trim();
            if (requestedSection) {
                activateSection(requestedSection);
            }
            else if (params.has('search') || params.has('sort') || params.has('page')) {
                activateSection('categories');
            }
            else if (params.has('productSearch') || params.has('productSort') || params.has('productPage')) {
                activateSection('products');
            }
            else {
                const firstAvailableSection = menuLinks[0]?.dataset.section;
                if (firstAvailableSection) {
                    activateSection(firstAvailableSection);
                }
            }
        }

        const shouldOpenDrawer = container?.dataset.openCategoryDrawer === 'true';
        if (shouldOpenDrawer) {
            activateSection('categories');
            openDrawer();
        }

        const shouldOpenProductDrawer = container?.dataset.openProductDrawer === 'true';
        if (shouldOpenProductDrawer) {
            activateSection('products');
            openProductDrawer();
        }

        const categoryFilterForm = document.getElementById('categoryFilterForm');
        const categorySearchInput = document.getElementById('categorySearchInput');
        const categorySortSelect = document.getElementById('categorySortSelect');
        const clearCategoryFiltersButton = document.getElementById('clearCategoryFilters');
        const categoryRowsContainer = document.querySelector('#categories tbody');
        const categoryPaginationBar = document.getElementById('categoryPaginationBar');
        const categoryPrevPage = document.getElementById('categoryPrevPage');
        const categoryNextPage = document.getElementById('categoryNextPage');
        const categoryPageInfo = document.getElementById('categoryPageInfo');
        const productFilterForm = document.getElementById('productFilterForm');
        const productSearchInput = document.getElementById('productSearchInput');
        const productSortSelect = document.getElementById('productSortSelect');
        const clearProductFiltersButton = document.getElementById('clearProductFilters');
        const productRowsContainer = document.querySelector('#products tbody');
        const productPaginationBar = document.getElementById('productPaginationBar');
        const productPrevPage = document.getElementById('productPrevPage');
        const productNextPage = document.getElementById('productNextPage');
        const productPageInfo = document.getElementById('productPageInfo');
        const inventorySearchInput = document.getElementById('inventorySearchInput');
        const inventoryCategoryFilter = document.getElementById('inventoryCategoryFilter');
        const inventoryStockFilter = document.getElementById('inventoryStockFilter');
        const inventorySortSelect = document.getElementById('inventorySortSelect');
        const inventoryTableBody = document.getElementById('inventoryTableBody');
        const inventoryPaginationBar = document.getElementById('inventoryPaginationBar');
        const inventoryPrevPage = document.getElementById('inventoryPrevPage');
        const inventoryNextPage = document.getElementById('inventoryNextPage');
        const inventoryPageInfo = document.getElementById('inventoryPageInfo');
        let searchDebounceTimer;
        let productSearchDebounceTimer;
        let inventorySearchDebounceTimer;
        const inventoryPageSize = 10;
        let inventoryCurrentPage = 1;
        const clientPageSize = 10;
        let categoryCurrentPage = 1;
        let productCurrentPage = 1;

        function paginateRows(rows, currentPage, pageSize) {
            const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
            const safePage = Math.min(Math.max(currentPage, 1), totalPages);
            const start = (safePage - 1) * pageSize;
            return {
                totalPages,
                safePage,
                pagedRows: rows.slice(start, start + pageSize)
            };
        }

        function applyCategoryFilters(resetPage = true) {
            if (!categoryRowsContainer) {
                return;
            }

            const rows = Array.from(categoryRowsContainer.querySelectorAll('tr[data-category-name]'));
            const term = (categorySearchInput?.value || '').trim().toLowerCase();
            const sort = (categorySortSelect?.value || 'az').toLowerCase();

            const filtered = rows.filter(row => {
                const name = row.dataset.categoryName || '';
                const description = row.dataset.categoryDescription || '';
                return !term || name.includes(term) || description.includes(term);
            });

            filtered.sort((left, right) => {
                const leftName = left.dataset.categoryName || '';
                const rightName = right.dataset.categoryName || '';
                return sort === 'za'
                    ? rightName.localeCompare(leftName, 'es')
                    : leftName.localeCompare(rightName, 'es');
            });

            if (resetPage) {
                categoryCurrentPage = 1;
            }

            const { totalPages, safePage, pagedRows } = paginateRows(filtered, categoryCurrentPage, clientPageSize);
            categoryCurrentPage = safePage;

            rows.forEach(row => {
                row.style.display = 'none';
            });

            const orderedRows = document.createDocumentFragment();
            pagedRows.forEach(row => {
                row.style.display = '';
                orderedRows.appendChild(row);
            });
            categoryRowsContainer.appendChild(orderedRows);

            if (categoryPaginationBar && categoryPrevPage && categoryNextPage && categoryPageInfo) {
                categoryPaginationBar.hidden = filtered.length <= clientPageSize;
                categoryPageInfo.textContent = `Página ${categoryCurrentPage} de ${totalPages}`;
                categoryPrevPage.disabled = categoryCurrentPage <= 1;
                categoryNextPage.disabled = categoryCurrentPage >= totalPages;
            }
        }

        categoryFilterForm?.addEventListener('submit', event => event.preventDefault());
        categorySearchInput?.addEventListener('input', () => {
            window.clearTimeout(searchDebounceTimer);
            searchDebounceTimer = window.setTimeout(() => applyCategoryFilters(true), 200);
        });
        categorySortSelect?.addEventListener('change', () => applyCategoryFilters(true));
        categoryPrevPage?.addEventListener('click', () => {
            categoryCurrentPage -= 1;
            applyCategoryFilters(false);
        });
        categoryNextPage?.addEventListener('click', () => {
            categoryCurrentPage += 1;
            applyCategoryFilters(false);
        });
        clearCategoryFiltersButton?.addEventListener('click', () => {
            if (categorySearchInput) {
                categorySearchInput.value = '';
            }

            if (categorySortSelect) {
                categorySortSelect.value = 'az';
            }

            applyCategoryFilters(true);
        });

        function applyProductFilters(resetPage = true) {
            if (!productRowsContainer) {
                return;
            }

            const rows = Array.from(productRowsContainer.querySelectorAll('tr[data-product-name]'));
            const term = (productSearchInput?.value || '').trim().toLowerCase();
            const sort = (productSortSelect?.value || 'az').toLowerCase();

            const filtered = rows.filter(row => {
                const name = row.dataset.productName || '';
                const description = row.dataset.productDescription || '';
                const category = row.dataset.productCategory || '';
                return !term || name.includes(term) || description.includes(term) || category.includes(term);
            });

            filtered.sort((left, right) => {
                const leftName = left.dataset.productName || '';
                const rightName = right.dataset.productName || '';
                return sort === 'za'
                    ? rightName.localeCompare(leftName, 'es')
                    : leftName.localeCompare(rightName, 'es');
            });

            if (resetPage) {
                productCurrentPage = 1;
            }

            const { totalPages, safePage, pagedRows } = paginateRows(filtered, productCurrentPage, clientPageSize);
            productCurrentPage = safePage;

            rows.forEach(row => {
                row.style.display = 'none';
            });

            pagedRows.forEach(row => {
                row.style.display = '';
            });

            if (productPaginationBar && productPrevPage && productNextPage && productPageInfo) {
                productPaginationBar.hidden = filtered.length <= clientPageSize;
                productPageInfo.textContent = `Página ${productCurrentPage} de ${totalPages}`;
                productPrevPage.disabled = productCurrentPage <= 1;
                productNextPage.disabled = productCurrentPage >= totalPages;
            }
        }

        productFilterForm?.addEventListener('submit', event => event.preventDefault());
        productSearchInput?.addEventListener('input', () => {
            window.clearTimeout(productSearchDebounceTimer);
            productSearchDebounceTimer = window.setTimeout(() => applyProductFilters(true), 200);
        });
        productSortSelect?.addEventListener('change', () => applyProductFilters(true));
        productPrevPage?.addEventListener('click', () => {
            productCurrentPage -= 1;
            applyProductFilters(false);
        });
        productNextPage?.addEventListener('click', () => {
            productCurrentPage += 1;
            applyProductFilters(false);
        });
        clearProductFiltersButton?.addEventListener('click', () => {
            if (productSearchInput) {
                productSearchInput.value = '';
            }

            if (productSortSelect) {
                productSortSelect.value = 'az';
            }

            applyProductFilters(true);
        });

        categoryRowsContainer?.addEventListener('click', event => {
            const editButton = event.target.closest('.category-edit-btn');
            if (!editButton) {
                return;
            }

            const row = editButton.closest('tr[data-category-id]');
            if (!row) {
                return;
            }

            setCategoryEditMode(row);
            activateSection('categories');
            openDrawer();
        });

        productRowsContainer?.addEventListener('click', event => {
            const editButton = event.target.closest('.product-edit-btn');
            if (!editButton) {
                return;
            }

            const row = editButton.closest('tr[data-product-id]');
            if (!row) {
                return;
            }

            setProductEditMode(row);
            activateSection('products');
            openProductDrawer();
        });

        function sortInventoryRows(rows, sortValue) {
            return rows.sort((leftRow, rightRow) => {
                const leftName = (leftRow.dataset.inventoryName || '').toLowerCase();
                const rightName = (rightRow.dataset.inventoryName || '').toLowerCase();
                const leftStock = Number(leftRow.dataset.inventoryStock || 0);
                const rightStock = Number(rightRow.dataset.inventoryStock || 0);

                switch (sortValue) {
                    case 'name_desc':
                        return rightName.localeCompare(leftName, 'es');
                    case 'stock_desc':
                        return rightStock - leftStock || leftName.localeCompare(rightName, 'es');
                    case 'stock_asc':
                        return leftStock - rightStock || leftName.localeCompare(rightName, 'es');
                    default:
                        return leftName.localeCompare(rightName, 'es');
                }
            });
        }

        function showInventoryEmptyRow(message) {
            if (!inventoryTableBody) {
                return;
            }

            let emptyRow = inventoryTableBody.querySelector('tr[data-inventory-empty="true"]');
            if (!emptyRow) {
                emptyRow = document.createElement('tr');
                emptyRow.setAttribute('data-inventory-empty', 'true');
                emptyRow.innerHTML = `<td colspan="5" class="inventory-empty">${message}</td>`;
                inventoryTableBody.appendChild(emptyRow);
                return;
            }

            const cell = emptyRow.querySelector('td');
            if (cell) {
                cell.textContent = message;
            }
        }

        function clearInventoryEmptyRow() {
            inventoryTableBody?.querySelector('tr[data-inventory-empty="true"]')?.remove();
        }

        function applyInventoryFilters(resetPage = true) {
            if (!inventoryTableBody) {
                return;
            }

            const searchValue = (inventorySearchInput?.value || '').trim().toLowerCase();
            const categoryValue = (inventoryCategoryFilter?.value || '').trim();
            const stockValue = inventoryStockFilter?.value || 'all';
            const sortValue = inventorySortSelect?.value || 'name_asc';
            const allRows = Array.from(inventoryTableBody.querySelectorAll('tr[data-inventory-name]'));
            const matchedRows = allRows.filter(row => {
                const rowName = (row.dataset.inventoryName || '').toLowerCase();
                const rowCategory = row.dataset.inventoryCategory || '';
                const stock = Number(row.dataset.inventoryStock || 0);
                const minStock = Number(row.dataset.inventoryMinStock || 0);

                const matchesSearch = !searchValue || rowName.includes(searchValue);
                const matchesCategory = !categoryValue || rowCategory === categoryValue;
                const matchesStock = stockValue === 'all'
                    || (stockValue === 'low' && stock <= minStock)
                    || (stockValue === 'out' && stock <= 0)
                    || (stockValue === 'high' && stock > minStock && stock > 0);

                return matchesSearch && matchesCategory && matchesStock;
            });

            const sortedRows = sortInventoryRows(matchedRows, sortValue);
            const totalPages = Math.max(1, Math.ceil(sortedRows.length / inventoryPageSize));
            if (resetPage) {
                inventoryCurrentPage = 1;
            }
            inventoryCurrentPage = Math.min(inventoryCurrentPage, totalPages);

            allRows.forEach(row => {
                row.style.display = 'none';
            });

            clearInventoryEmptyRow();
            if (!sortedRows.length) {
                showInventoryEmptyRow('No hay productos que coincidan con el filtro aplicado.');
                if (inventoryPaginationBar) {
                    inventoryPaginationBar.hidden = true;
                }
                return;
            }

            const startIndex = (inventoryCurrentPage - 1) * inventoryPageSize;
            const pagedRows = sortedRows.slice(startIndex, startIndex + inventoryPageSize);
            pagedRows.forEach(row => {
                row.style.display = '';
            });

            if (inventoryPaginationBar && inventoryPageInfo && inventoryPrevPage && inventoryNextPage) {
                inventoryPaginationBar.hidden = totalPages <= 1;
                inventoryPageInfo.textContent = `Página ${inventoryCurrentPage} de ${totalPages}`;
                inventoryPrevPage.disabled = inventoryCurrentPage <= 1;
                inventoryNextPage.disabled = inventoryCurrentPage >= totalPages;
            }
        }

        inventorySearchInput?.addEventListener('input', () => {
            window.clearTimeout(inventorySearchDebounceTimer);
            inventorySearchDebounceTimer = window.setTimeout(() => applyInventoryFilters(true), 200);
        });
        inventoryCategoryFilter?.addEventListener('change', () => applyInventoryFilters(true));
        inventoryStockFilter?.addEventListener('change', () => applyInventoryFilters(true));
        inventorySortSelect?.addEventListener('change', () => applyInventoryFilters(true));
        inventoryPrevPage?.addEventListener('click', () => {
            if (inventoryCurrentPage <= 1) {
                return;
            }

            inventoryCurrentPage -= 1;
            applyInventoryFilters(false);
        });
        inventoryNextPage?.addEventListener('click', () => {
            inventoryCurrentPage += 1;
            applyInventoryFilters(false);
        });
        applyInventoryFilters(true);

        const adminUserForm = document.getElementById('adminUserForm');
        const adminUserIdInput = document.getElementById('adminUserId');
        const adminUserFirstName = document.getElementById('adminUserFirstName');
        const adminUserLastName = document.getElementById('adminUserLastName');
        const adminUserEmail = document.getElementById('adminUserEmail');
        const adminUserPhone = document.getElementById('adminUserPhone');
        const adminUserRole = document.getElementById('adminUserRole');
        const adminUserPassword = document.getElementById('adminUserPassword');
        const userPasswordLabel = document.getElementById('userPasswordLabel');
        const userFormTitle = document.getElementById('userFormTitle');
        const saveUserButton = document.getElementById('saveUserButton');
        const cancelUserEditButton = document.getElementById('cancelUserEdit');
        const userFormStatus = document.getElementById('userFormStatus');
        const usersTableBody = document.getElementById('usersTableBody');
        const usersTable = document.getElementById('usersTable');
        const userSearchInput = document.getElementById('userSearchInput');
        const userRoleFilter = document.getElementById('userRoleFilter');
        const clearUserFiltersButton = document.getElementById('clearUserFilters');
        const usersPaginationBar = document.getElementById('usersPaginationBar');
        const usersPrevPage = document.getElementById('usersPrevPage');
        const usersNextPage = document.getElementById('usersNextPage');
        const usersPageInfo = document.getElementById('usersPageInfo');
        const usersTotalCount = document.getElementById('usersTotalCount');
        const usersAdminsCount = document.getElementById('usersAdminsCount');
        const usersSellersCount = document.getElementById('usersSellersCount');
        const adminPermissionSearchInput = document.getElementById('adminPermissionSearchInput');
        const adminPermissionSelect = document.getElementById('adminPermissionSelect');
        const adminPermissionList = document.getElementById('adminPermissionList');
        const antiForgeryToken = adminUserForm?.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const notificationToggle = document.getElementById('notificationToggle');
        const notificationPanel = document.getElementById('notificationPanel');
        const notificationList = document.getElementById('notificationList');
        const notificationBadge = document.getElementById('notificationBadge');
        const notificationCountLabel = document.getElementById('notificationCountLabel');
        const clearNotificationsButton = document.getElementById('clearNotificationsButton');
        let currentEditSnapshot = null;
        let usersCurrentPage = 1;

        function normalizePhone(value) {
            return (value || '').replace(/\D/g, '');
        }

        function applyAdminPermissionFilters() {
            if (!adminPermissionList) {
                return;
            }

            const term = (adminPermissionSearchInput?.value || '').trim().toLowerCase();
            const selectedEmail = (adminPermissionSelect?.value || '').trim().toLowerCase();
            const cards = Array.from(adminPermissionList.querySelectorAll('.permission-card'));

            cards.forEach(card => {
                const email = (card.dataset.adminEmail || '').toLowerCase();
                const name = (card.dataset.adminName || '').toLowerCase();
                const matchesSearch = !term || name.includes(term) || email.includes(term);
                const matchesSelection = !selectedEmail || email === selectedEmail;
                card.style.display = matchesSearch && matchesSelection ? '' : 'none';
            });
        }

        function wirePermissionToggles() {
            if (!adminPermissionList) {
                return;
            }

            adminPermissionList.querySelectorAll('.permission-card form').forEach(form => {
                if (form.dataset.permissionsWired === 'true') {
                    return;
                }

                const allToggle = form.querySelector('.all-permissions-toggle');
                const checkboxes = Array.from(form.querySelectorAll('input[type="checkbox"]'));
                const areaCheckboxes = checkboxes.filter(node => !node.classList.contains('all-permissions-toggle'));

                function syncAllToggle() {
                    if (!allToggle) {
                        return;
                    }

                    allToggle.checked = areaCheckboxes.every(node => node.checked);
                }

                allToggle?.addEventListener('change', () => {
                    const checked = allToggle.checked;
                    areaCheckboxes.forEach(node => {
                        node.checked = checked;
                    });
                });

                areaCheckboxes.forEach(node => {
                    node.addEventListener('change', syncAllToggle);
                });

                syncAllToggle();
                form.dataset.permissionsWired = 'true';
            });
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function rebuildPermissionSelectOptions() {
            if (!adminPermissionSelect || !adminPermissionList) {
                return;
            }

            const cards = Array.from(adminPermissionList.querySelectorAll('.permission-card'));
            adminPermissionSelect.innerHTML = '<option value="">Selecciona un administrador</option>';

            cards
                .sort((a, b) => (a.dataset.adminName || '').localeCompare(b.dataset.adminName || '', 'es'))
                .forEach(card => {
                    const option = document.createElement('option');
                    option.value = card.dataset.adminEmail || '';
                    option.textContent = card.dataset.adminName || card.dataset.adminEmail || 'Administrador';
                    adminPermissionSelect.appendChild(option);
                });
        }

        function ensurePermissionEmptyState() {
            const panel = document.getElementById('adminPermissionsPanel');
            if (!panel || !adminPermissionList) {
                return;
            }

            const hasCards = adminPermissionList.querySelector('.permission-card') !== null;
            let empty = panel.querySelector('.permission-empty');

            if (!hasCards && !empty) {
                empty = document.createElement('p');
                empty.className = 'permission-empty';
                empty.textContent = 'No hay otros administradores para configurar.';
                panel.appendChild(empty);
            }

            if (hasCards && empty) {
                empty.remove();
            }
        }

        function buildPermissionCardMarkup(user) {
            const fullName = `${user.firstName || ''} ${user.lastName || ''}`.trim();
            const safeName = escapeHtml(fullName || 'Administrador');
            const safeEmail = escapeHtml(user.email || '');

            return `
                <form action="@Url.Action("UpdateAdminPermissions", "Home")" method="post">
                    <input name="__RequestVerificationToken" type="hidden" value="${escapeHtml(antiForgeryToken || '')}" />
                    <input type="hidden" name="email" value="${safeEmail}" />
                    <div class="permission-card-header">
                        <div>
                            <strong>${safeName}</strong>
                            <small>${safeEmail}</small>
                        </div>
                        <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Guardar</button>
                    </div>
                    <div class="permission-grid">
                        <label class="permission-check"><input type="checkbox" name="allPermissions" value="true" class="all-permissions-toggle" /> Todos los permisos</label>
                        <label class="permission-check"><input type="checkbox" name="dashboard" value="true" /> Dashboard</label>
                        <label class="permission-check"><input type="checkbox" name="products" value="true" /> Productos</label>
                        <label class="permission-check"><input type="checkbox" name="inventory" value="true" /> Inventario</label>
                        <label class="permission-check"><input type="checkbox" name="users" value="true" /> Gestión de usuarios</label>
                        <label class="permission-check"><input type="checkbox" name="categories" value="true" /> Categorías</label>
                        <label class="permission-check"><input type="checkbox" name="permissions" value="true" /> Panel de permisos</label>
                        <label class="permission-check"><input type="checkbox" name="orders" value="true" /> Pedidos</label>
                        <label class="permission-check"><input type="checkbox" name="support" value="true" /> Mensajes de contacto</label>
                    </div>
                </form>`;
        }

        function syncPermissionPanelForRoleChange(user, previousRole, updatedRole, previousEmail) {
            const panel = document.getElementById('adminPermissionsPanel');
            if (!panel || !adminPermissionList || !user) {
                return;
            }

            const currentAdminEmail = (panel.dataset.currentAdminEmail || '').trim().toLowerCase();
            const normalizedEmail = (user.email || '').trim().toLowerCase();
            const normalizedPreviousEmail = (previousEmail || '').trim().toLowerCase();

            if (normalizedPreviousEmail && normalizedPreviousEmail !== normalizedEmail) {
                adminPermissionList.querySelector(`.permission-card[data-admin-email="${normalizedPreviousEmail}"]`)?.remove();
            }

            if (updatedRole === 'administrador' && normalizedEmail && normalizedEmail !== currentAdminEmail) {
                const fullName = `${user.firstName || ''} ${user.lastName || ''}`.trim();
                let card = adminPermissionList.querySelector(`.permission-card[data-admin-email="${normalizedEmail}"]`);

                if (!card) {
                    card = document.createElement('article');
                    card.className = 'permission-card';
                    adminPermissionList.prepend(card);
                }

                card.dataset.adminEmail = normalizedEmail;
                card.dataset.adminName = fullName;
                card.innerHTML = buildPermissionCardMarkup(user);
            }
            else if (previousRole === 'administrador' || updatedRole !== 'administrador') {
                adminPermissionList.querySelector(`.permission-card[data-admin-email="${normalizedEmail}"]`)?.remove();
            }

            rebuildPermissionSelectOptions();
            ensurePermissionEmptyState();
            wirePermissionToggles();
            applyAdminPermissionFilters();
        }

        function updateNotificationCounter(unreadCount) {
            if (notificationBadge) {
                notificationBadge.textContent = `${unreadCount}`;
                notificationBadge.style.display = unreadCount > 0 ? 'flex' : 'none';
            }

            if (notificationCountLabel) {
                notificationCountLabel.textContent = unreadCount > 0
                    ? `${unreadCount} sin leer`
                    : 'Sin pendientes';
            }
        }

        function ensureNotificationEmptyState() {
            if (!notificationList) {
                return;
            }

            const hasItems = notificationList.querySelector('li.notification-item') !== null;
            let empty = notificationList.querySelector('#notificationEmpty');
            if (!hasItems && !empty) {
                empty = document.createElement('li');
                empty.id = 'notificationEmpty';
                empty.className = 'notification-empty';
                empty.textContent = 'Sin notificaciones';
                notificationList.appendChild(empty);
            }

            if (hasItems && empty) {
                empty.remove();
            }
        }

        function appendNotification(notification) {
            if (!notificationList || !notification) {
                return;
            }

            const item = document.createElement('li');
            item.className = 'notification-item unread';
            item.dataset.notificationId = notification.id;

            const info = document.createElement('div');
            info.className = 'notification-main';
            const avatar = document.createElement('div');
            avatar.className = 'notification-avatar';
            avatar.innerHTML = '<i class="fas fa-bell"></i>';
            const content = document.createElement('div');
            content.className = 'notification-content';
            const message = document.createElement('div');
            message.className = 'notification-message';
            message.textContent = notification.message || 'Nueva notificación';
            const meta = document.createElement('div');
            meta.className = 'meta';
            const createdAt = notification.createdAtUtc ? new Date(notification.createdAtUtc) : new Date();
            meta.textContent = createdAt.toLocaleString();

            content.appendChild(message);
            content.appendChild(meta);
            info.appendChild(avatar);
            info.appendChild(content);

            const readButton = document.createElement('button');
            readButton.type = 'button';
            readButton.className = 'link-icon notification-read-btn';
            readButton.title = 'Marcar como leída';
            readButton.innerHTML = '<i class="fas fa-check"></i>';

            item.appendChild(info);
            item.appendChild(readButton);
            notificationList.prepend(item);

            ensureNotificationEmptyState();
        }

        async function markNotificationAsRead(item) {
            if (!item || !notificationList?.dataset.markUrl || !antiForgeryToken) {
                return;
            }

            const id = item.dataset.notificationId;
            if (!id) {
                return;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);
            formData.append('id', id);

            const response = await fetch(notificationList.dataset.markUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: formData
            });

            const payload = await response.json();
            if (!response.ok || !payload.succeeded) {
                return;
            }

            item.classList.remove('unread');
            item.querySelector('.notification-read-btn')?.remove();
            updateNotificationCounter(payload.unreadCount ?? 0);
        }

        async function clearNotifications() {
            if (!notificationList?.dataset.clearUrl || !antiForgeryToken) {
                return;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);

            const response = await fetch(notificationList.dataset.clearUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: formData
            });

            const payload = await response.json();
            if (!response.ok || !payload.succeeded) {
                return;
            }

            notificationList.querySelectorAll('li.notification-item').forEach(node => node.remove());
            ensureNotificationEmptyState();
            updateNotificationCounter(0);
        }

        function getFieldValidationMessage(field) {
            if (!field) {
                return 'Formulario inválido.';
            }

            if (field.validity.valueMissing) {
                if (field.id === 'adminUserFirstName') return 'El nombre es obligatorio.';
                if (field.id === 'adminUserLastName') return 'El apellido es obligatorio.';
                if (field.id === 'adminUserEmail') return 'El correo es obligatorio.';
                if (field.id === 'adminUserPhone') return 'El teléfono es obligatorio.';
                if (field.id === 'adminUserPassword') return 'La contraseña es obligatoria.';
                if (field.id === 'adminUserRole') return 'El rol es obligatorio.';
            }

            if (field.validity.typeMismatch && field.id === 'adminUserEmail') {
                return 'El correo debe tener un formato válido (ejemplo@dominio.com).';
            }

            if (field.validity.patternMismatch) {
                if (field.id === 'adminUserPhone') {
                    return 'El teléfono solo debe contener números.';
                }

                if (field.id === 'adminUserPassword') {
                    return 'La contraseña debe tener al menos 8 caracteres, una mayúscula y un símbolo.';
                }
            }

            return 'Hay campos inválidos en el formulario.';
        }

        function wireUserFormValidation() {
            if (!adminUserForm) {
                return;
            }

            const fields = adminUserForm.querySelectorAll('input, select');
            fields.forEach(field => {
                field.addEventListener('invalid', event => {
                    const currentField = event.target;
                    currentField.setCustomValidity(getFieldValidationMessage(currentField));
                });

                field.addEventListener('input', event => {
                    event.target.setCustomValidity('');
                });

                field.addEventListener('change', event => {
                    event.target.setCustomValidity('');
                });
            });
        }

        function clearUserFormCustomValidity() {
            if (!adminUserForm) {
                return;
            }

            const fields = adminUserForm.querySelectorAll('input, select');
            fields.forEach(field => field.setCustomValidity(''));
        }

        function showUserStatus(message, isError = false) {
            if (!userFormStatus) {
                return;
            }

            userFormStatus.style.display = 'block';
            userFormStatus.textContent = message;
            userFormStatus.classList.toggle('error-message', isError);
            userFormStatus.classList.toggle('status-message', !isError);
        }

        function clearUserStatus() {
            if (!userFormStatus) {
                return;
            }

            userFormStatus.style.display = 'none';
            userFormStatus.textContent = '';
            userFormStatus.classList.remove('error-message');
            userFormStatus.classList.remove('status-message');
        }

        function normalizeUserRole(role) {
            return (role || '').toLowerCase() === 'administrador' ? 'administrador' : 'vendedor';
        }

        function canManageRoles() {
            return adminUserRole?.dataset.canManageRoles === 'true';
        }

        function userRoleBadge(role) {
            const normalizedRole = normalizeUserRole(role);
            return `<span class="role-badge ${normalizedRole === 'administrador' ? 'admin' : ''}">${normalizedRole === 'administrador' ? 'Administrador' : 'Vendedor'}</span>`;
        }

        function setCreateMode() {
            if (!adminUserForm) {
                return;
            }

            adminUserForm.reset();
            clearUserFormCustomValidity();
            currentEditSnapshot = null;
            if (adminUserIdInput) {
                adminUserIdInput.value = '';
            }

            if (adminUserPassword) {
                adminUserPassword.required = true;
            }

            if (adminUserRole) {
                adminUserRole.disabled = false;
                if (!canManageRoles()) {
                    adminUserRole.value = 'vendedor';
                }
            }

            if (userPasswordLabel) {
                userPasswordLabel.textContent = 'Contraseña *';
            }

            if (userFormTitle) {
                userFormTitle.innerHTML = '<i class="fas fa-user-plus" style="margin-right: 8px;"></i>Registrar nuevo usuario';
            }

            if (saveUserButton) {
                saveUserButton.innerHTML = '<i class="fas fa-save"></i> Guardar usuario';
            }
        }

        function setEditMode(row) {
            if (!row) {
                return;
            }

            clearUserFormCustomValidity();

            const normalizedPhone = normalizePhone(row.dataset.userPhone || '');

            if (adminUserIdInput) {
                adminUserIdInput.value = row.dataset.userId || '';
            }

            if (adminUserFirstName) {
                adminUserFirstName.value = row.dataset.userFirstName || '';
            }

            if (adminUserLastName) {
                adminUserLastName.value = row.dataset.userLastName || '';
            }

            if (adminUserEmail) {
                adminUserEmail.value = row.dataset.userEmail || '';
            }

            if (adminUserPhone) {
                adminUserPhone.value = normalizedPhone;
            }

            if (adminUserRole) {
                adminUserRole.value = normalizeUserRole(row.dataset.userRole);
                adminUserRole.disabled = !canManageRoles();
            }

            if (adminUserPassword) {
                adminUserPassword.value = '';
                adminUserPassword.required = false;
            }

            if (userPasswordLabel) {
                userPasswordLabel.textContent = 'Contraseña (opcional)';
            }

            if (userFormTitle) {
                userFormTitle.innerHTML = '<i class="fas fa-user-edit" style="margin-right: 8px;"></i>Editar usuario';
            }

            if (saveUserButton) {
                saveUserButton.innerHTML = '<i class="fas fa-sync-alt"></i> Actualizar usuario';
            }

            currentEditSnapshot = {
                firstName: (row.dataset.userFirstName || '').trim(),
                lastName: (row.dataset.userLastName || '').trim(),
                email: (row.dataset.userEmail || '').trim().toLowerCase(),
                phone: normalizedPhone,
                role: normalizeUserRole(row.dataset.userRole),
                password: ''
            };
        }

        function getCurrentFormSnapshot() {
            return {
                firstName: (adminUserFirstName?.value || '').trim(),
                lastName: (adminUserLastName?.value || '').trim(),
                email: (adminUserEmail?.value || '').trim().toLowerCase(),
                phone: normalizePhone(adminUserPhone?.value || ''),
                role: normalizeUserRole(adminUserRole?.value || ''),
                password: (adminUserPassword?.value || '').trim()
            };
        }

        function hasUserChanges() {
            if (!currentEditSnapshot) {
                return true;
            }

            const currentSnapshot = getCurrentFormSnapshot();
            return currentSnapshot.firstName !== currentEditSnapshot.firstName
                || currentSnapshot.lastName !== currentEditSnapshot.lastName
                || currentSnapshot.email !== currentEditSnapshot.email
                || currentSnapshot.phone !== currentEditSnapshot.phone
                || currentSnapshot.role !== currentEditSnapshot.role
                || currentSnapshot.password.length > 0;
        }

        function getUserRows() {
            return Array.from(usersTableBody?.querySelectorAll('tr[data-user-id]') || []);
        }

        function renderEmptyUsersRow() {
            if (!usersTableBody) {
                return;
            }

            const userRows = getUserRows();
            let emptyRow = usersTableBody.querySelector('.users-empty-row');

            if (userRows.length === 0) {
                if (!emptyRow) {
                    emptyRow = document.createElement('tr');
                    emptyRow.className = 'users-empty-row';
                    emptyRow.innerHTML = '<td colspan="5">No hay usuarios registrados con rol administrador o vendedor.</td>';
                    usersTableBody.appendChild(emptyRow);
                }
            } else if (emptyRow) {
                emptyRow.remove();
            }
        }

        function updateUserStats() {
            const rows = getUserRows();
            const admins = rows.filter(row => normalizeUserRole(row.dataset.userRole) === 'administrador').length;
            const sellers = rows.length - admins;

            if (usersTotalCount) {
                usersTotalCount.textContent = `${rows.length}`;
            }

            if (usersAdminsCount) {
                usersAdminsCount.textContent = `${admins}`;
            }

            if (usersSellersCount) {
                usersSellersCount.textContent = `${sellers}`;
            }
        }

        function upsertUserRow(user) {
            if (!usersTableBody) {
                return;
            }

            const normalizedRole = normalizeUserRole(user.role);
            const fullName = `${user.firstName || ''} ${user.lastName || ''}`.trim();
            let row = usersTableBody.querySelector(`tr[data-user-id="${user.id}"]`);

            if (!row) {
                row = document.createElement('tr');
                usersTableBody.prepend(row);
            }

            row.dataset.userId = user.id;
            row.dataset.userRole = normalizedRole;
            row.dataset.userName = fullName;
            row.dataset.userEmail = user.email || '';
            row.dataset.userPhone = user.phone || '';
            row.dataset.userFirstName = user.firstName || '';
            row.dataset.userLastName = user.lastName || '';
            row.innerHTML = `
                <td class="user-name">${fullName || '-'}</td>
                <td class="user-email">${user.email || '-'}</td>
                <td class="user-phone">${user.phone || '-'}</td>
                <td class="user-role">${userRoleBadge(normalizedRole)}</td>
                <td class="action-icons">
                    <button type="button" class="link-icon user-edit-btn" title="Editar"><i class="fas fa-edit"></i></button>
                    <button type="button" class="link-icon user-delete-btn" title="Eliminar"><i class="fas fa-trash-alt"></i></button>
                </td>`;

            renderEmptyUsersRow();
            updateUserStats();
            applyUserFilters();
        }

        function applyUserFilters(resetPage = true) {
            const searchTerm = (userSearchInput?.value || '').trim().toLowerCase();
            const role = normalizeUserRole(userRoleFilter?.value || '');
            const hasRoleFilter = !!(userRoleFilter?.value || '').trim();

            const rows = getUserRows();
            const filteredRows = rows.filter(row => {
                const rowName = (row.dataset.userName || '').toLowerCase();
                const rowEmail = (row.dataset.userEmail || '').toLowerCase();
                const rowRole = normalizeUserRole(row.dataset.userRole);
                const matchesSearch = !searchTerm || rowName.includes(searchTerm) || rowEmail.includes(searchTerm);
                const matchesRole = !hasRoleFilter || rowRole === role;

                return matchesSearch && matchesRole;
            });

            if (resetPage) {
                usersCurrentPage = 1;
            }

            const { totalPages, safePage, pagedRows } = paginateRows(filteredRows, usersCurrentPage, clientPageSize);
            usersCurrentPage = safePage;

            rows.forEach(row => {
                row.style.display = 'none';
            });

            pagedRows.forEach(row => {
                row.style.display = '';
            });

            const hasDataRows = rows.length > 0;
            let emptyRow = usersTableBody?.querySelector('.users-empty-row');
            if (hasDataRows && filteredRows.length === 0) {
                if (!emptyRow) {
                    emptyRow = document.createElement('tr');
                    emptyRow.className = 'users-empty-row';
                    emptyRow.innerHTML = '<td colspan="5">No hay usuarios que coincidan con los filtros.</td>';
                    usersTableBody?.appendChild(emptyRow);
                } else {
                    emptyRow.innerHTML = '<td colspan="5">No hay usuarios que coincidan con los filtros.</td>';
                }
            } else if (hasDataRows && emptyRow) {
                emptyRow.remove();
            }

            if (usersPaginationBar && usersPrevPage && usersNextPage && usersPageInfo) {
                usersPaginationBar.hidden = filteredRows.length <= clientPageSize;
                usersPageInfo.textContent = `Página ${usersCurrentPage} de ${totalPages}`;
                usersPrevPage.disabled = usersCurrentPage <= 1;
                usersNextPage.disabled = usersCurrentPage >= totalPages;
            }
        }

        async function submitUserForm(event) {
            event.preventDefault();
            if (!adminUserForm) {
                return;
            }

            clearUserStatus();

            const isEditMode = !!adminUserIdInput?.value;
            if (isEditMode && !hasUserChanges()) {
                const continueWithoutChanges = window.confirm('No se ha hecho ningún cambio. ¿Deseas continuar con la actualización?');
                if (!continueWithoutChanges) {
                    showUserStatus('Realiza los cambios que necesites y vuelve a presionar actualizar.', true);
                    return;
                }

                setCreateMode();
                showUserStatus('No se realizaron cambios. El usuario mantiene su información actual.');
                return;
            }

            if (!adminUserForm.checkValidity()) {
                const invalidField = adminUserForm.querySelector(':invalid');
                const message = getFieldValidationMessage(invalidField);
                showUserStatus(message, true);
                invalidField?.reportValidity();
                return;
            }

            const endpoint = isEditMode ? adminUserForm.dataset.updateUrl : adminUserForm.dataset.createUrl;
            const formData = new FormData(adminUserForm);

            if (!canManageRoles()) {
                const preservedRole = isEditMode
                    ? (currentEditSnapshot?.role || normalizeUserRole(adminUserRole?.value || 'vendedor'))
                    : 'vendedor';
                formData.set('Role', preservedRole);
            }

            saveUserButton?.setAttribute('disabled', 'disabled');

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });

                let payload = null;
                try {
                    payload = await response.json();
                } catch {
                    payload = { succeeded: false, errorMessage: 'No se pudo completar el registro. Verifica tu sesión e inténtalo de nuevo.' };
                }

                if (!response.ok || !payload.succeeded) {
                    showUserStatus(payload.errorMessage || 'No se pudo guardar el usuario.', true);
                    return;
                }

                const updatedRole = normalizeUserRole(payload.user?.role || '');
                const existingRow = payload.user?.id
                    ? usersTableBody?.querySelector(`tr[data-user-id="${payload.user.id}"]`)
                    : null;
                const previousEmail = (existingRow?.dataset.userEmail || currentEditSnapshot?.email || '').trim().toLowerCase();
                const previousRole = normalizeUserRole(existingRow?.dataset.userRole || currentEditSnapshot?.role || '');
                const affectsAdminPermissions = previousRole !== updatedRole
                    && (updatedRole === 'administrador' || previousRole === 'administrador');

                upsertUserRow(payload.user);
                if (payload.notification) {
                    appendNotification(payload.notification);
                    updateNotificationCounter(payload.unreadCount ?? 0);
                }

                setCreateMode();
                showUserStatus(isEditMode ? 'Usuario actualizado correctamente.' : 'Usuario creado correctamente.');

                if (affectsAdminPermissions && document.getElementById('adminPermissionsPanel')) {
                    syncPermissionPanelForRoleChange(payload.user, previousRole, updatedRole, previousEmail);
                }
            } catch {
                showUserStatus('No se pudo completar la operación con Supabase.', true);
            } finally {
                saveUserButton?.removeAttribute('disabled');
            }
        }

        async function deleteUser(row) {
            if (!row || !usersTable?.dataset.deleteUrl || !antiForgeryToken) {
                return;
            }

            const userId = row.dataset.userId;
            if (!userId) {
                return;
            }

            if (!window.confirm('¿Eliminar este usuario?')) {
                return;
            }

            clearUserStatus();

            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);
            formData.append('id', userId);

            try {
                const response = await fetch(usersTable.dataset.deleteUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });

                let payload = null;
                try {
                    payload = await response.json();
                } catch {
                    payload = { succeeded: false, errorMessage: 'No se pudo eliminar el usuario. Verifica tu sesión e inténtalo de nuevo.' };
                }

                if (!response.ok || !payload.succeeded) {
                    showUserStatus(payload.errorMessage || 'No se pudo eliminar el usuario.', true);
                    return;
                }

                const removedRole = normalizeUserRole(row.dataset.userRole || '');

                row.remove();
                renderEmptyUsersRow();
                updateUserStats();
                applyUserFilters();
                setCreateMode();
                showUserStatus('Usuario eliminado correctamente.');
                if (payload.notification) {
                    appendNotification(payload.notification);
                    updateNotificationCounter(payload.unreadCount ?? 0);
                }

                if (removedRole === 'administrador' && document.getElementById('adminPermissionsPanel')) {
                    syncPermissionPanelForRoleChange(
                        { email: row.dataset.userEmail, firstName: row.dataset.userFirstName, lastName: row.dataset.userLastName },
                        removedRole,
                        'vendedor',
                        row.dataset.userEmail || '');
                }
            } catch {
                showUserStatus('No se pudo completar la operación con Supabase.', true);
            }
        }

        adminUserForm?.addEventListener('submit', submitUserForm);

        cancelUserEditButton?.addEventListener('click', () => {
            setCreateMode();
            clearUserStatus();
        });

        usersTableBody?.addEventListener('click', async event => {
            const button = event.target.closest('button');
            if (!button) {
                return;
            }

            const row = button.closest('tr[data-user-id]');
            if (!row) {
                return;
            }

            if (button.classList.contains('user-edit-btn')) {
                setEditMode(row);
                clearUserStatus();
                window.scrollTo({ top: adminUserForm?.offsetTop ? adminUserForm.offsetTop - 120 : 0, behavior: 'smooth' });
                return;
            }

            if (button.classList.contains('user-delete-btn')) {
                await deleteUser(row);
            }
        });

        userSearchInput?.addEventListener('input', () => applyUserFilters(true));
        userRoleFilter?.addEventListener('change', () => applyUserFilters(true));
        usersPrevPage?.addEventListener('click', () => {
            usersCurrentPage -= 1;
            applyUserFilters(false);
        });
        usersNextPage?.addEventListener('click', () => {
            usersCurrentPage += 1;
            applyUserFilters(false);
        });
        adminPermissionSearchInput?.addEventListener('input', applyAdminPermissionFilters);
        adminPermissionSelect?.addEventListener('change', applyAdminPermissionFilters);
        clearUserFiltersButton?.addEventListener('click', () => {
            if (userSearchInput) {
                userSearchInput.value = '';
            }

            if (userRoleFilter) {
                userRoleFilter.value = '';
            }

            applyUserFilters(true);
        });

        notificationToggle?.addEventListener('click', event => {
            event.stopPropagation();
            notificationPanel?.classList.toggle('open');
        });

        notificationPanel?.addEventListener('click', event => {
            event.stopPropagation();
            const button = event.target.closest('.notification-read-btn');
            if (!button) {
                return;
            }

            const item = button.closest('.notification-item');
            if (!item) {
                return;
            }

            markNotificationAsRead(item);
        });

        document.addEventListener('click', () => {
            notificationPanel?.classList.remove('open');
        });

        clearNotificationsButton?.addEventListener('click', clearNotifications);

        setCreateMode();
        wireUserFormValidation();
        renderEmptyUsersRow();
        updateUserStats();
        applyCategoryFilters(true);
        applyProductFilters(true);
        applyUserFilters(true);
        applyAdminPermissionFilters();
        wirePermissionToggles();
        applyInventoryFilters();
        updateNotificationCounter(@Model.UnreadNotificationsCount);
        ensureNotificationEmptyState();
    })();
</script>