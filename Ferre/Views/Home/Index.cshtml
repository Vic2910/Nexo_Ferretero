@{
    ViewData["Title"] = "NexoFerretero";
    Layout = "_LayoutPublic";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
}

<!-- Elementos de fondo fijo -->
<div class="fixed-background"></div>
<div class="overlay"></div>

<!-- ================= HEADER ================= -->
<header>
    <div class="logo-container" onclick="location.href='@Url.Content("~/Index")'">
        <div class="logo-icon">
            <svg width="40" height="40" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <path d="M50 5 L85 25 L85 65 L50 85 L15 65 L15 25 Z" fill="none" stroke="#ff5722" stroke-width="12" stroke-linejoin="round"/>
                <path d="M50 25 L85 45 L85 85 L50 105 L15 85 L15 45 Z" fill="none" stroke="#fff" stroke-width="12" stroke-linejoin="round" transform="translate(0, -10) scale(0.9)"/>
                <path d="M25 45 L50 60 L75 45" fill="none" stroke="#fff" stroke-width="10" stroke-linejoin="round"/>
            </svg>
        </div>
        <div class="logo-text">
            NEXO<span>FERRETERO</span>
        </div>
    </div>

    <nav>
        <a onclick="location.href='@Url.Content("~/Index")'">Inicio</a>
        <a href="@Url.Action("Portada", "Home")">Productos</a>
        <a href="#">Contacto</a>
    </nav>
</header>

<!-- ================= HERO ================= -->
<section class="hero">
    <div class="hero-content">
        <h1>Construye con <span>Confianza</span> y <span>Precisión</span></h1>
        <p>
            Encuentra herramientas y materiales de calidad con NEXO Ferretero.
            Más de 15 años siendo tu aliado en cada proyecto.
        </p>

        <div>
            <a href="@Url.Action("Login", "Home")" class="btn primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3" />
                </svg>
                Iniciar Sesión
            </a>
            <a href="@Url.Action("Cuenta", "Home")" class="btn secondary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 8 0 4 4 0 0 0-8 0M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                Registrarse
            </a>
        </div>
    </div>
</section>

<!-- ================= CATEGORÍAS - ANCHO COMPLETO ================= -->
<section class="categorias">
    <div class="categorias-container">
        <h2>Nuestras Categorías</h2>
        <p>Explora todo lo que tenemos para ti</p>
    </div>

    <div class="carousel-container">
        <button class="arrow left" onclick="moveSlide(-1)">❮</button>

        <div class="carousel" id="carousel">
            <div class="card">
                <span class="card-icon">🔨</span>
                <h3>Herramientas</h3>
                <p>Martillos, destornilladores y más</p>
            </div>
            <div class="card">
                <span class="card-icon">🪚</span>
                <h3>Carpintería</h3>
                <p>Sierras, cepillos y accesorios</p>
            </div>
            <div class="card">
                <span class="card-icon">🔌</span>
                <h3>Electricidad</h3>
                <p>Cables, interruptores, iluminación</p>
            </div>
            <div class="card">
                <span class="card-icon">🚰</span>
                <h3>Fontanería</h3>
                <p>Tuberías, conexiones y más</p>
            </div>
            <div class="card">
                <span class="card-icon">🎨</span>
                <h3>Pinturas</h3>
                <p>Pinturas, brochas y acabados</p>
            </div>
            <div class="card">
                <span class="card-icon">🏗️</span>
                <h3>Construcción</h3>
                <p>Cemento, varillas, blocks</p>
            </div>
        </div>

        <button class="arrow right" onclick="moveSlide(1)">❯</button>
    </div>
</section>

<!-- ================= FOOTER CUSTOM - ANCHO COMPLETO ================= -->
<footer class="footer-custom">
    <div class="footer-container">
        <div class="footer-content">
            <div class="footer-section">
                <h3>NEXO Ferretero</h3>
                <p>Calidad y confianza en cada proyecto. Tu aliado indiscutible en herramientas y materiales de construcción.</p>
                <div class="social-links">
                    <a href="#">📘</a>
                    <a href="#">📷</a>
                    <a href="#">🐦</a>
                    <a href="#">📱</a>
                </div>
            </div>
            <div class="footer-section">
                <h3>Categorías</h3>
                <ul>
                    <li><a href="#">Herramientas</a></li>
                    <li><a href="#">Carpintería</a></li>
                    <li><a href="#">Electricidad</a></li>
                    <li><a href="#">Fontanería</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h3>Información</h3>
                <ul>
                    <li><a href="#">Sobre Nosotros</a></li>
                    <li><a href="#">Políticas</a></li>
                    <li><a href="#">Envíos</a></li>
                    <li><a href="#">Garantías</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h3>Contacto</h3>
                <ul>
                    <li>📍 Dirección</li>
                    <li>📞 Teléfono</li>
                    <li>✉️ Email</li>
                    <li>🕒 Horario</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2026 NEXO Ferretero — Calidad y confianza. Todos los derechos reservados.</p>
        </div>
    </div>
</footer>

@section Scripts {
    <script src="~/js/pages/index.js" asp-append-version="true"></script>
}
