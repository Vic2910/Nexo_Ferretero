@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Restablecer Contraseńa - Ferretería";
    Layout = "_LayoutPublic";
}

@{
    var headerModel = new PublicHeaderModel(
        new[]
        {
            new NavItem("Inicio", Url.Action("Index", "Home") ?? "#"),
            new NavItem("Productos", Url.Action("Portada", "Home") ?? "#"),
            new NavItem("Contacto", "#")
        },
        Url.Content("~/RecursosF/log.jpeg"),
        Url.Action("Index", "Home") ?? "#");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/reset-password.css" asp-append-version="true" />
}

@await Html.PartialAsync("_PublicHeader", headerModel)

<div class="reset-wrapper">
    <div class="reset-card">
        <div class="reset-icon">
            <svg viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="22" r="12" fill="#F57C00" />
                <path d="M16 54c0-10 8-16 16-16s16 6 16 16" fill="#1F2A44" />
                <path d="M26 34h12" stroke="#FFFFFF" stroke-width="3" />
                <path d="M32 28v12" stroke="#FFFFFF" stroke-width="3" />
            </svg>
        </div>

        <div class="reset-header">
            <h1>Restablecer contraseńa</h1>
            <p>Ingresa el código de 6 dígitos y define tu nueva contraseńa.</p>
            <p>Si abriste el enlace del correo, los datos se completan automáticamente.</p>
        </div>

        <form asp-action="ResetPassword" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="AccessToken" type="hidden" />
            <input asp-for="RefreshToken" type="hidden" />
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 12px;"></div>
            @if (ViewBag.StatusMessage is not null)
            {
                <div class="status-message">@ViewBag.StatusMessage</div>
            }

            <div class="form-group">
                <label>Correo electrónico</label>
                <div class="input-wrapper">
                    <span>??</span>
                    <input asp-for="Email" type="email" placeholder="ejemplo@correo.com" required>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Código de verificación</label>
                <div class="input-wrapper">
                    <span>??</span>
                    <input asp-for="RecoveryCode" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" placeholder="123456" required>
                </div>
                <span asp-validation-for="RecoveryCode" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Nueva contraseńa</label>
                <div class="input-wrapper">
                    <span>??</span>
                    <input asp-for="Password" type="password" required>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Confirmar contraseńa</label>
                <div class="input-wrapper">
                    <span>?</span>
                    <input asp-for="ConfirmPassword" type="password" required>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="reset-btn">
                Guardar nueva contraseńa
            </button>
        </form>

        <div class="login-link">
            żYa la restableciste? <a href="@Url.Action("Login", "Home")">Inicia sesión</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const hashParams = new URLSearchParams(window.location.hash.replace('#', ''));
        const accessToken = hashParams.get('access_token');
        const refreshToken = hashParams.get('refresh_token');

        if (accessToken) {
            document.querySelector('input[name="AccessToken"]').value = accessToken;
            const emailInput = document.querySelector('input[name="Email"]');
            if (emailInput) {
                emailInput.removeAttribute('required');
            }
            const recoveryCodeInput = document.querySelector('input[name="RecoveryCode"]');
            if (recoveryCodeInput) {
                recoveryCodeInput.removeAttribute('required');
                recoveryCodeInput.value = '';
            }
        }

        if (refreshToken) {
            document.querySelector('input[name="RefreshToken"]').value = refreshToken;
        }
    </script>
}
