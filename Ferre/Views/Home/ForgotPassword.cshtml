@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar Contraseña - Ferretería";
    Layout = "_LayoutPublic";
}

@{
    var headerModel = new PublicHeaderModel(
        new[]
        {
            new NavItem("Inicio", Url.Action("Index", "Home") ?? "#"),
            new NavItem("Productos", Url.Action("Portada", "Home") ?? "#"),
            new NavItem("Contacto", "#")
        },
        Url.Content("~/RecursosF/log.jpeg"),
        Url.Action("Index", "Home") ?? "#");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/forgot-password.css" asp-append-version="true" />
}

@* Navbar *@
@await Html.PartialAsync("_PublicHeader", headerModel)

<div class="forgot-wrapper">
    <div class="forgot-card">
        <div class="forgot-icon">
            <svg viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="22" r="12" fill="#F57C00" />
                <path d="M16 54c0-10 8-16 16-16s16 6 16 16" fill="#1F2A44" />
                <path d="M32 30v8" stroke="#FFFFFF" stroke-width="3" />
                <circle cx="32" cy="42" r="2" fill="#FFFFFF" />
            </svg>
        </div>

        <div class="forgot-header">
            <h1>Recuperar contraseña</h1>
            <p>Te enviaremos un correo con enlace y/o código de verificación para restablecer tu contraseña.</p>
        </div>

        <form asp-action="ForgotPassword" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 12px;"></div>
            @if (ViewBag.StatusMessage is not null)
            {
                <div class="status-message">@ViewBag.StatusMessage</div>
            }
            <div class="form-group">
                <label>Correo electrónico</label>
                <div class="input-wrapper">
                    <span>??</span>
                    <input asp-for="Email" type="email" placeholder="ejemplo@correo.com" required>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="forgot-btn">
                Enviar código
            </button>
        </form>

        <div class="login-link">
            ¿Recordaste tu contraseña? <a href="@Url.Action("Login", "Home")">Inicia sesión</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
