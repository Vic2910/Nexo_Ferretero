@model RegisterViewModel

@{
    ViewData["Title"] = "Crear Cuenta - Ferretería";
    Layout = "_LayoutPublic";
}

@{
    var headerModel = new PublicHeaderModel(
        new[]
        {
            new NavItem("Inicio", Url.Action("Index", "Home") ?? "#"),
            new NavItem("Productos", Url.Action("Portada", "Home") ?? "#"),
            new NavItem("Contacto", "#")
        },
        Url.Content("~/RecursosF/log.jpeg"),
        Url.Action("Index", "Home") ?? "#");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cuenta.css" asp-append-version="true" />
}

@* Navbar *@
@await Html.PartialAsync("_PublicHeader", headerModel)

<div class="register-wrapper">
    <div class="register-card">

        <div class="register-icon">
            <svg viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="20" r="12" fill="#F57C00" />
                <path d="M14 56c0-10 8-16 18-16s18 6 18 16" fill="#1F2A44" />
                <circle cx="50" cy="50" r="8" fill="#F57C00" />
                <path d="M50 46v8M46 50h8" stroke="white" stroke-width="2" />
            </svg>
        </div>

        <div class="register-header">
            <h1>Crear Cuenta</h1>
            <p>Completa los datos para registrarte</p>
        </div>

        <form asp-action="Cuenta" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 12px;"></div>
            <div class="form-group">
                <label>Nombre</label>
                <div class="input-wrapper">
                    <input asp-for="FirstName" type="text" required>
                </div>
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Apellido</label>
                <div class="input-wrapper">
                    <input asp-for="LastName" type="text" required>
                </div>
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Correo electrónico</label>
                <div class="input-wrapper">
                    <input asp-for="Email" type="email" required>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Teléfono</label>
                <div class="input-wrapper">
                    <input asp-for="Phone" type="tel" required>
                </div>
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <div class="input-wrapper has-toggle">
                    <input asp-for="Password" id="registerPassword" type="password" required>
                    <button type="button" class="toggle-password" data-target="registerPassword" aria-label="Mostrar contraseña">
                        <svg class="eye-icon eye-open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M12 5c5.5 0 9.6 3.3 11 7-1.4 3.7-5.5 7-11 7S2.4 15.7 1 12c1.4-3.7 5.5-7 11-7Zm0 2C7.8 7 4.5 9.4 3.1 12 4.5 14.6 7.8 17 12 17s7.5-2.4 8.9-5C19.5 9.4 16.2 7 12 7Zm0 2.5A2.5 2.5 0 1 1 9.5 12 2.5 2.5 0 0 1 12 9.5Z" />
                        </svg>
                        <svg class="eye-icon eye-closed is-hidden" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="m3.3 2 18.7 18.7-1.4 1.4-3.2-3.2A12.4 12.4 0 0 1 12 20c-5.5 0-9.6-3.3-11-7a13.8 13.8 0 0 1 4.2-5.3L1.9 3.4 3.3 2Zm3.4 7.6A10.8 10.8 0 0 0 3.1 13c1.4 2.6 4.7 5 8.9 5 1.4 0 2.7-.3 3.9-.8l-2-2a3.5 3.5 0 0 1-4.1-4.1l-3.1-3.1Zm5.5-4.5c5.5 0 9.6 3.3 11 7a13.6 13.6 0 0 1-4 5.2l-1.5-1.5c1.3-1 2.4-2.2 3.1-3.7-1.4-2.6-4.7-5-8.9-5-.8 0-1.5.1-2.2.2L8 5.9c1.3-.5 2.7-.8 4.2-.8Zm-.2 3.1a3.8 3.8 0 0 1 3.8 3.8c0 .5-.1 1-.3 1.5l-5-5c.5-.2 1-.3 1.5-.3Z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Confirmar contraseña</label>
                <div class="input-wrapper has-toggle">
                    <input asp-for="ConfirmPassword" id="registerConfirmPassword" type="password" required>
                    <button type="button" class="toggle-password" data-target="registerConfirmPassword" aria-label="Mostrar contraseña">
                        <svg class="eye-icon eye-open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M12 5c5.5 0 9.6 3.3 11 7-1.4 3.7-5.5 7-11 7S2.4 15.7 1 12c1.4-3.7 5.5-7 11-7Zm0 2C7.8 7 4.5 9.4 3.1 12 4.5 14.6 7.8 17 12 17s7.5-2.4 8.9-5C19.5 9.4 16.2 7 12 7Zm0 2.5A2.5 2.5 0 1 1 9.5 12 2.5 2.5 0 0 1 12 9.5Z" />
                        </svg>
                        <svg class="eye-icon eye-closed is-hidden" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="m3.3 2 18.7 18.7-1.4 1.4-3.2-3.2A12.4 12.4 0 0 1 12 20c-5.5 0-9.6-3.3-11-7a13.8 13.8 0 0 1 4.2-5.3L1.9 3.4 3.3 2Zm3.4 7.6A10.8 10.8 0 0 0 3.1 13c1.4 2.6 4.7 5 8.9 5 1.4 0 2.7-.3 3.9-.8l-2-2a3.5 3.5 0 0 1-4.1-4.1l-3.1-3.1Zm5.5-4.5c5.5 0 9.6 3.3 11 7a13.6 13.6 0 0 1-4 5.2l-1.5-1.5c1.3-1 2.4-2.2 3.1-3.7-1.4-2.6-4.7-5-8.9-5-.8 0-1.5.1-2.2.2L8 5.9c1.3-.5 2.7-.8 4.2-.8Zm-.2 3.1a3.8 3.8 0 0 1 3.8 3.8c0 .5-.1 1-.3 1.5l-5-5c.5-.2 1-.3 1.5-.3Z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="register-btn">
                Crear Cuenta
            </button>
        </form>

        <div class="login-link">
            ¿Ya tienes cuenta? <a href="@Url.Action("Login", "Home")">Inicia sesión aquí</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/password-toggle.js" asp-append-version="true"></script>
}

