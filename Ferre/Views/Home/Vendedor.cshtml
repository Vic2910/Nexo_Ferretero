@model VendedorDashboardViewModel

@{
    ViewData["Title"] = "Panel Vendedor - NEXO Ferretero";
    Layout = "_LayoutPublic";
    var sellerName = Context.Session.GetString("UserName") ?? "Vendedor";
    var helloName = sellerName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? sellerName;
    var requestedSection = (Context.Request.Query["section"].FirstOrDefault() ?? "inventory").Trim().ToLowerInvariant();
    var activeSection = requestedSection == "orders" ? "orders" : "inventory";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/vendedor.css" asp-append-version="true" />
}

@section Head {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
}

<nav class="seller-navbar">
    <div class="logo">
        <a href="@Url.Action("Index", "Home")" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
            <img src="~/RecursosF/log.jpeg" alt="NEXO Ferretero">
            <span>NEXOFerretero</span>
        </a>
    </div>

    <div class="nav-actions">
        <div class="notification-icon">
            <button type="button" class="notification-trigger" id="notificationToggle" aria-label="Notificaciones">
                <span>🔔</span>
                <span class="notification-badge" id="notificationBadge">@Model.UnreadNotificationsCount</span>
            </button>

            <div class="notification-panel" id="notificationPanel">
                <div class="notification-header">
                    <span>Notificaciones</span>
                    <small id="notificationCountLabel">@Model.UnreadNotificationsCount sin leer</small>
                </div>
                <ul class="notification-list" id="notificationList"
                    data-mark-url="@Url.Action("MarkNotificationAsRead", "Home")"
                    data-clear-url="@Url.Action("ClearNotifications", "Home")">
                    @if (!Model.Notifications.Any())
                    {
                        <li class="notification-empty" id="notificationEmpty">Sin notificaciones</li>
                    }
                    else
                    {
                        foreach (var notification in Model.Notifications.OrderByDescending(x => x.CreatedAtUtc))
                        {
                            <li class="notification-item @(notification.IsRead ? string.Empty : "unread")" data-notification-id="@notification.Id">
                                <div class="notification-main">
                                    <div class="notification-avatar"><i class="fas fa-bell"></i></div>
                                    <div class="notification-content">
                                        <div class="notification-message">@notification.Message</div>
                                        <div class="meta">@notification.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </div>
                                @if (!notification.IsRead)
                                {
                                    <button type="button" class="link-icon notification-read-btn" title="Marcar como leída">
                                        <i class="fas fa-check"></i>
                                    </button>
                                }
                            </li>
                        }
                    }
                </ul>
                <div class="notification-actions">
                    <button type="button" class="btn-secondary" id="clearNotificationsButton">Limpiar</button>
                </div>
            </div>
        </div>

        <form id="notificationFormToken" style="display:none;">
            @Html.AntiForgeryToken()
        </form>

        <div class="profile-dropdown">
            <div class="profile-avatar">@helloName.Substring(0, 1).ToUpperInvariant()</div>
            <div class="profile-info">
                <div class="name">@sellerName</div>
                <div class="role">Vendedor</div>
            </div>
            <div class="dropdown-menu">
                <form asp-action="Logout" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Cerrar sesión
                    </button>
                </form>
            </div>
        </div>
    </div>
</nav>

<div class="seller-container">
    <aside class="seller-sidebar">
        <div class="seller-profile">
            <div class="seller-avatar">@helloName.Substring(0, 1).ToUpperInvariant()</div>
            <div class="seller-meta">
                <h4>@sellerName</h4>
                <p>Vendedor</p>
            </div>
        </div>
        <ul class="seller-menu">
            <li><a href="#inventory" data-section="inventory" class="@(activeSection == "orders" ? string.Empty : "active")"><i class="fas fa-warehouse"></i> Inventario</a></li>
            <li><a href="#orders" data-section="orders" class="@(activeSection == "orders" ? "active" : string.Empty)"><i class="fas fa-receipt"></i> Pedidos</a></li>
        </ul>
    </aside>

    <main class="seller-content">
        <div class="seller-header">
            <div>
                <h1>Hola, @helloName</h1>
                <p>@sellerName · Control de stock y atención de pedidos.</p>
            </div>
        </div>

        <section id="inventory" class="seller-section @(activeSection == "orders" ? string.Empty : "active")">
            <div class="stock-mini-toolbar">
                <div class="inventory-search">
                    <i class="fas fa-search"></i>
                    <input type="text" id="inventorySearchInput" placeholder="Buscar por nombre" autocomplete="off" />
                </div>
                <select id="inventoryCategoryFilter" class="inventory-select">
                    <option value="">Todas las categorías</option>
                    @foreach (var option in Model.CategoryOptions.OrderBy(x => x.Name))
                    {
                        <option value="@option.Name">@option.Name</option>
                    }
                </select>
                <select id="inventoryStockFilter" class="inventory-select">
                    <option value="all">Todos</option>
                    <option value="low">Por vencer (stock ≤ mínimo)</option>
                    <option value="out">Sin stock</option>
                    <option value="high">Stock más alto</option>
                </select>
            </div>

            <section class="table-section">
                <table class="inventory-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Stock</th>
                            <th>Stock mínimo</th>
                            <th>Alerta</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryTableBody">
                        @if (!Model.InventoryProducts.Any())
                        {
                            <tr>
                                <td colspan="5" class="inventory-empty">No hay productos en inventario.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var product in Model.InventoryProducts)
                            {
                                var categoryName = Model.CategoryOptions.FirstOrDefault(c => c.Id == product.CategoryId)?.Name ?? "Sin categoría";
                                var isOutOfStock = product.Stock <= 0;
                                var isLowStock = !isOutOfStock && product.Stock < product.MinStock;
                                <tr data-inventory-name="@product.Name" data-inventory-category="@categoryName" data-inventory-stock="@product.Stock" data-inventory-min-stock="@product.MinStock">
                                    <td>@product.Name</td>
                                    <td>@categoryName</td>
                                    <td class="@(isLowStock ? "stock-low" : string.Empty)">@product.Stock</td>
                                    <td>@product.MinStock</td>
                                    <td>
                                        @if (isOutOfStock)
                                        {
                                            <span class="stock-alert-badge out">⚠ Sin stock</span>
                                        }
                                        else if (isLowStock)
                                        {
                                            <span class="stock-alert-badge low">⚠ Stock bajo</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </section>
        </section>

        <section id="orders" class="seller-section @(activeSection == "orders" ? "active" : string.Empty)">
            @{
                var deliveredOrders = Model.Orders
                    .Where(x => string.Equals(x.Status, "entregado", StringComparison.OrdinalIgnoreCase))
                    .ToList();
                var activeOrders = Model.Orders
                    .Where(x => !string.Equals(x.Status, "entregado", StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="seller-alert success">@successMessage</div>
            }

            @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="seller-alert error">@errorMessage</div>
            }

            <form asp-action="Vendedor" method="get" class="orders-filter-bar">
                <input type="hidden" name="section" value="orders" />
                <div class="orders-filter-group">
                    <label for="ordersStatusFilter">Estado</label>
                    <select id="ordersStatusFilter" name="status" class="inventory-select">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(Model.StatusFilter) ? "selected" : null)">Todos</option>
                        <option value="pendiente" selected="@(string.Equals(Model.StatusFilter, "pendiente", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Pendiente</option>
                        <option value="pagado" selected="@(string.Equals(Model.StatusFilter, "pagado", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Pagado</option>
                        <option value="cancelado" selected="@(string.Equals(Model.StatusFilter, "cancelado", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Cancelado</option>
                        <option value="entregado" selected="@(string.Equals(Model.StatusFilter, "entregado", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Entregado</option>
                    </select>
                </div>
                <div class="orders-filter-group">
                    <label for="ordersReceiptFilter">Últimos 4 del ticket</label>
                    <input id="ordersReceiptFilter"
                           name="receipt"
                           class="orders-search-input"
                           type="text"
                           inputmode="numeric"
                           pattern="[0-9]*"
                           maxlength="4"
                           placeholder="Ej: 4759"
                           value="@Model.ReceiptSearchFilter" />
                </div>
                <div class="orders-filter-actions">
                    <button type="submit" class="btn-secondary">Buscar</button>
                    <a class="btn-secondary" href="@Url.Action("Vendedor", new { section = "orders" })">Limpiar</a>
                </div>
            </form>

            <section class="table-section">
                <div class="orders-table-title">Pedidos en atención</div>
                <table class="inventory-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Tipo de pago</th>
                            <th>Método</th>
                            <th>Total</th>
                            <th>Comprobante</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!activeOrders.Any())
                        {
                            <tr>
                                <td colspan="9" class="inventory-empty">No hay pedidos para el filtro seleccionado.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in activeOrders)
                            {
                                var normalizedStatus = (order.Status ?? string.Empty).Trim().ToLowerInvariant();
                                var isPending = string.Equals(normalizedStatus, "pendiente", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "pending", StringComparison.Ordinal);
                                var isPaid = string.Equals(normalizedStatus, "pagado", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "paid", StringComparison.Ordinal);
                                var isCanceled = string.Equals(normalizedStatus, "cancelado", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "cancelada", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "cancelados", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "canceladas", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "anulado", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "anulada", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "canceled", StringComparison.Ordinal)
                                    || string.Equals(normalizedStatus, "cancelled", StringComparison.Ordinal);
                                var isCashPayment = string.Equals(order.PaymentMethod, "Efectivo", StringComparison.OrdinalIgnoreCase);
                                var isCardPayment = string.Equals(order.PaymentMethod, "Tarjeta", StringComparison.OrdinalIgnoreCase);
                                var isPayPalPayment = string.Equals(order.PaymentMethod, "PayPal", StringComparison.OrdinalIgnoreCase);
                                var showCanceledStatus = isCanceled || isPayPalPayment;
                                var statusText = showCanceledStatus
                                    ? "Cancelado"
                                    : (isPending ? "Pendiente" : (isPaid ? "Pagado" : "Cancelado"));
                                var statusClass = showCanceledStatus ? "order-status-canceled" : string.Empty;
                                var paymentStatusText = isCashPayment ? "Local" : "Pago en línea";
                                var paymentMethodClass = isCardPayment
                                    ? "payment-method-badge card"
                                    : (isCashPayment
                                        ? "payment-method-badge cash"
                                        : (isPayPalPayment ? "payment-method-badge paypal" : "payment-method-badge"));
                                <tr>
                                    <td>@order.ReceiptNumber</td>
                                    <td>@order.UserEmail</td>
                                    <td>@order.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="@statusClass">@statusText</span></td>
                                    <td>@paymentStatusText</td>
                                    <td><span class="@paymentMethodClass">@order.PaymentMethod</span></td>
                                    <td>@order.Total.ToString("C")</td>
                                    <td>
                                        <button type="button" class="btn-secondary js-open-receipt-preview" data-receipt-url="@Url.Action("PreviewOrderReceiptPdf", new { receiptId = order.Id })">Ver</button>
                                    </td>
                                    <td class="order-actions-cell">
                                        @if (isPending && isCashPayment)
                                        {
                                            <form asp-action="RegisterCashOrderPayment" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="receiptId" value="@order.Id" />
                                                <input type="hidden" name="status" value="@Model.StatusFilter" />
                                                <input type="hidden" name="receipt" value="@Model.ReceiptSearchFilter" />
                                                <button type="submit" class="btn-secondary">Cobrar efectivo</button>
                                            </form>
                                        }
                                        <form asp-action="MarkOrderAsDelivered" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="receiptId" value="@order.Id" />
                                            <input type="hidden" name="status" value="@Model.StatusFilter" />
                                            <input type="hidden" name="receipt" value="@Model.ReceiptSearchFilter" />
                                            @if (isPaid)
                                            {
                                                <button type="submit" class="btn-secondary">Marcar entregado</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn-secondary" disabled="disabled">Marcar entregado</button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </section>

            <section class="table-section delivered-orders-section">
                <div class="orders-table-title">Pedidos entregados</div>
                <table class="inventory-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Fecha pedido</th>
                            <th>Fecha entrega</th>
                            <th>Tipo de pago</th>
                            <th>Método</th>
                            <th>Total</th>
                            <th>Comprobante</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!deliveredOrders.Any())
                        {
                            <tr>
                                <td colspan="8" class="inventory-empty">No hay pedidos entregados.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in deliveredOrders)
                            {
                                var isCashPayment = string.Equals(order.PaymentMethod, "Efectivo", StringComparison.OrdinalIgnoreCase);
                                var isCardPayment = string.Equals(order.PaymentMethod, "Tarjeta", StringComparison.OrdinalIgnoreCase);
                                var isPayPalPayment = string.Equals(order.PaymentMethod, "PayPal", StringComparison.OrdinalIgnoreCase);
                                var paymentMethodClass = isCardPayment
                                    ? "payment-method-badge card"
                                    : (isCashPayment
                                        ? "payment-method-badge cash"
                                        : (isPayPalPayment ? "payment-method-badge paypal" : "payment-method-badge"));
                                <tr>
                                    <td>@order.ReceiptNumber</td>
                                    <td>@order.UserEmail</td>
                                    <td>@order.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(order.DeliveredAtUtc.HasValue ? order.DeliveredAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-")</td>
                                    <td>@(isCashPayment ? "Local" : "Pago en línea")</td>
                                    <td><span class="@paymentMethodClass">@order.PaymentMethod</span></td>
                                    <td>@order.Total.ToString("C")</td>
                                    <td>
                                        <button type="button" class="btn-secondary js-open-receipt-preview" data-receipt-url="@Url.Action("PreviewOrderReceiptPdf", new { receiptId = order.Id })">Ver</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </section>
        </section>
    </main>
</div>

<div id="receiptPreviewModal" class="receipt-preview-modal" aria-hidden="true">
    <div class="receipt-preview-dialog" role="dialog" aria-modal="true" aria-label="Vista previa del comprobante">
        <button type="button" id="closeReceiptPreview" class="receipt-preview-close" aria-label="Cerrar">×</button>
        <iframe id="receiptPreviewFrame" class="receipt-preview-frame" title="Comprobante PDF"></iframe>
    </div>
</div>

<script>
    (function () {
        const notificationToggle = document.getElementById('notificationToggle');
        const notificationPanel = document.getElementById('notificationPanel');
        const notificationList = document.getElementById('notificationList');
        const notificationBadge = document.getElementById('notificationBadge');
        const notificationCountLabel = document.getElementById('notificationCountLabel');
        const clearNotificationsButton = document.getElementById('clearNotificationsButton');
        const antiForgeryToken = document.querySelector('#notificationFormToken input[name="__RequestVerificationToken"]')?.value;
        const inventorySearchInput = document.getElementById('inventorySearchInput');
        const inventoryCategoryFilter = document.getElementById('inventoryCategoryFilter');
        const inventoryStockFilter = document.getElementById('inventoryStockFilter');
        const inventoryTableBody = document.getElementById('inventoryTableBody');
        const menuLinks = document.querySelectorAll('.seller-menu a[data-section]');
        const sections = document.querySelectorAll('.seller-section');
        const receiptPreviewModal = document.getElementById('receiptPreviewModal');
        const receiptPreviewFrame = document.getElementById('receiptPreviewFrame');
        const closeReceiptPreviewButton = document.getElementById('closeReceiptPreview');
        const openReceiptPreviewButtons = document.querySelectorAll('.js-open-receipt-preview');

        function normalizeText(value) {
            return (value || '')
                .toString()
                .trim()
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
        }

        function updateNotificationCounter(unreadCount) {
            if (notificationBadge) {
                notificationBadge.textContent = `${unreadCount}`;
                notificationBadge.style.display = unreadCount > 0 ? 'flex' : 'none';
            }

            if (notificationCountLabel) {
                notificationCountLabel.textContent = unreadCount > 0
                    ? `${unreadCount} sin leer`
                    : 'Sin pendientes';
            }
        }

        function openReceiptPreview(url) {
            if (!receiptPreviewModal || !receiptPreviewFrame || !url) {
                return;
            }

            receiptPreviewFrame.src = url;
            receiptPreviewModal.classList.add('open');
            receiptPreviewModal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('modal-open');
        }

        function closeReceiptPreview() {
            if (!receiptPreviewModal || !receiptPreviewFrame) {
                return;
            }

            receiptPreviewModal.classList.remove('open');
            receiptPreviewModal.setAttribute('aria-hidden', 'true');
            receiptPreviewFrame.removeAttribute('src');
            document.body.classList.remove('modal-open');
        }

        function ensureNotificationEmptyState() {
            if (!notificationList) {
                return;
            }

            const hasItems = notificationList.querySelector('li.notification-item') !== null;
            let empty = notificationList.querySelector('#notificationEmpty');
            if (!hasItems && !empty) {
                empty = document.createElement('li');
                empty.id = 'notificationEmpty';
                empty.className = 'notification-empty';
                empty.textContent = 'Sin notificaciones';
                notificationList.appendChild(empty);
            }

            if (hasItems && empty) {
                empty.remove();
            }
        }

        async function markNotificationAsRead(item) {
            if (!item || !notificationList?.dataset.markUrl || !antiForgeryToken) {
                return;
            }

            const id = item.dataset.notificationId;
            if (!id) {
                return;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);
            formData.append('id', id);

            const response = await fetch(notificationList.dataset.markUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            });

            const payload = await response.json();
            if (!response.ok || !payload.succeeded) {
                return;
            }

            item.classList.remove('unread');
            item.querySelector('.notification-read-btn')?.remove();
            updateNotificationCounter(payload.unreadCount ?? 0);
        }

        async function clearNotifications() {
            if (!notificationList?.dataset.clearUrl || !antiForgeryToken) {
                return;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', antiForgeryToken);

            const response = await fetch(notificationList.dataset.clearUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            });

            const payload = await response.json();
            if (!response.ok || !payload.succeeded) {
                return;
            }

            notificationList.querySelectorAll('li.notification-item').forEach(node => node.remove());
            ensureNotificationEmptyState();
            updateNotificationCounter(0);
        }

        function applyInventoryFilters() {
            if (!inventoryTableBody) {
                return;
            }

            const searchValue = normalizeText(inventorySearchInput?.value || '');
            const selectedCategory = normalizeText(inventoryCategoryFilter?.value || '');
            const stockValue = inventoryStockFilter?.value || 'all';
            const rows = Array.from(inventoryTableBody.querySelectorAll('tr[data-inventory-name]'));

            rows.forEach(row => {
                const rowName = normalizeText(row.dataset.inventoryName || '');
                const rowCategory = normalizeText(row.dataset.inventoryCategory || '');
                const stock = Number(row.dataset.inventoryStock || 0);
                const minStock = Number(row.dataset.inventoryMinStock || 0);

                const matchesSearch = !searchValue || rowName.includes(searchValue);
                const matchesCategory = !selectedCategory || rowCategory === selectedCategory;
                const matchesStock = stockValue === 'all'
                    || (stockValue === 'low' && stock > 0 && stock < minStock)
                    || (stockValue === 'out' && stock <= 0)
                    || (stockValue === 'high' && stock > minStock && stock > 0);

                row.style.display = matchesSearch && matchesCategory && matchesStock ? '' : 'none';
            });
        }

        function activateSection(sectionId) {
            sections.forEach(section => {
                section.classList.remove('active');
            });

            menuLinks.forEach(link => {
                link.classList.remove('active');
            });

            const targetSection = document.getElementById(sectionId);
            const targetLink = document.querySelector(`.seller-menu a[data-section="${sectionId}"]`);
            if (targetSection) {
                targetSection.classList.add('active');
            }

            if (targetLink) {
                targetLink.classList.add('active');
            }
        }

        notificationToggle?.addEventListener('click', event => {
            event.stopPropagation();
            notificationPanel?.classList.toggle('open');
        });

        notificationPanel?.addEventListener('click', event => {
            event.stopPropagation();
            const button = event.target.closest('.notification-read-btn');
            if (!button) {
                return;
            }

            const item = button.closest('.notification-item');
            if (!item) {
                return;
            }

            markNotificationAsRead(item);
        });

        document.addEventListener('click', () => {
            notificationPanel?.classList.remove('open');
        });

        clearNotificationsButton?.addEventListener('click', clearNotifications);
        inventorySearchInput?.addEventListener('input', applyInventoryFilters);
        inventoryCategoryFilter?.addEventListener('change', applyInventoryFilters);
        inventoryStockFilter?.addEventListener('change', applyInventoryFilters);
        menuLinks.forEach(link => {
            link.addEventListener('click', event => {
                event.preventDefault();
                const sectionId = link.dataset.section;
                if (!sectionId) {
                    return;
                }

                activateSection(sectionId);
            });
        });

        openReceiptPreviewButtons.forEach(button => {
            button.addEventListener('click', () => {
                openReceiptPreview(button.dataset.receiptUrl);
            });
        });

        closeReceiptPreviewButton?.addEventListener('click', closeReceiptPreview);
        receiptPreviewModal?.addEventListener('click', event => {
            if (event.target === receiptPreviewModal) {
                closeReceiptPreview();
            }
        });

        document.addEventListener('keydown', event => {
            if (event.key === 'Escape') {
                closeReceiptPreview();
            }
        });

        updateNotificationCounter(@Model.UnreadNotificationsCount);
        ensureNotificationEmptyState();
        applyInventoryFilters();
        activateSection('@activeSection');
    })();
</script>