@model CategoryFormModel

@{
    ViewData["Title"] = "Editar Categoría - Administración";
    Layout = "_LayoutPublic";
}

@{
    var headerModel = new PublicHeaderModel(
        new[]
        {
            new NavItem("Inicio", Url.Action("Index", "Home") ?? "#"),
            new NavItem("Productos", "#"),
            new NavItem("Ofertas", "#"),
            new NavItem("Contacto", "#")
        },
        Url.Content("~/RecursosF/log.jpeg"),
        Url.Action("Index", "Home") ?? "#");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/categories.css" asp-append-version="true" />
}

@section Head {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
}

@await Html.PartialAsync("_PublicHeader", headerModel)

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-profile">
            <div class="admin-avatar">A</div>
            <div class="admin-info">
                <h4>Administrador</h4>
                <p>admin@nexo.com</p>
            </div>
        </div>
        <ul class="admin-menu">
            <li><a href="@Url.Action("Admin", "Home")"><i class="fas fa-chart-pie"></i> Dashboard</a></li>
            <li><a href="#"><i class="fas fa-box"></i> Productos</a></li>
            <li><a href="#"><i class="fas fa-shopping-cart"></i> Pedidos</a></li>
            <li><a href="#"><i class="fas fa-users"></i> Usuarios</a></li>
            <li><a href="@Url.Action("Index", "Categories")" class="active"><i class="fas fa-tag"></i> Categorías</a></li>
            <li><a href="#"><i class="fas fa-cog"></i> Configuración</a></li>
            <li><a href="#"><i class="fas fa-headset"></i> Soporte</a></li>
            <li><a href="#"><i class="fas fa-sign-out-alt"></i> Cerrar sesión</a></li>
        </ul>
    </aside>

    <main class="admin-content">
        <div class="admin-header">
            <div>
                <h1>Editar categoría</h1>
                <p>Actualiza el nombre o descripción de la categoría.</p>
            </div>
        </div>

        <section class="table-section">
            <form asp-action="Edit" method="post" class="category-form">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input asp-for="Name" type="text" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <input asp-for="Description" type="text" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary">Guardar cambios</button>
                    <a href="@Url.Action("Index", "Categories")" class="btn-secondary">Cancelar</a>
                </div>
            </form>
        </section>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
